node_modules/
bun.lock
pnpm-lock.yaml
dist/
dist-runtime/
.DS_Store
*.tsbuildinfo
.worktrees/

# Build artifacts
build/
!build/entitlements.mac.plist
!build/entitlements.runtime.plist
# src/runtime/build/ is hand-authored source (the runtime esbuild config used
# by `build:runtime` and the tarball build), NOT a build-output dir — re-include
# it so a clean checkout / CI can build the runtime daemon + its ripgrep.
!src/runtime/build/
!src/runtime/build/**
release/
test-results/

# Generated by `npm run dev:update` (local updater feed config)
dev-app-update.yml

# Claude Code
.claude/

# Cate workspace + local session state
.cate/

# Local logo scratch dir
_logos/

# Temp dirs from runtime daemon tests (deleted on teardown; ignored here in
# case a run is interrupted before afterAll fires)
cate-local-ws-*/
cate-local-install-*/
cate-daemon-ws-*/
